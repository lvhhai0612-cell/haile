<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <title>Thi Trắc Nghiệm Ngành Điện</title>
    <link rel="stylesheet" href="style.css">
</head>
<body>
    <div class="container">
        <h1>Hệ Thống Thi Trắc Nghiệm</h1>
        <div class="controls">
            <button onclick="startQuiz(60)">Làm 60 câu</button>
            <button onclick="startQuiz(280)">Làm toàn bộ</button>
        </div>

        <div id="quiz-box" style="display:none;">
            <div id="timer">Thời gian còn lại: <span id="time">--:--</span></div>
            <div id="quiz-content"></div>
            <button class="btn-submit" onclick="submitQuiz()">Nộp bài</button>
        </div>

        <div id="result-box" style="display:none;">
            <h2>Kết quả của bạn</h2>
            <p id="score"></p>
            <button onclick="location.reload()">Làm lại</button>
        </div>
    </div>
    <script src="script.js"></script>
</body>
</html>

